# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# 커스텀 로그인/회원가입 페이지 경로
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# FastAPI 백엔드 API 기본 주소 (로컬 개발용)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# 운영 도메인 (Open Graph/Twitter 카드의 absolute URL, sitemap, robots 에 사용).
# 로컬에선 fallback 으로 http://localhost:3000 사용. Vercel 운영에선 실제 도메인 입력.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# 하나로 SSO 공직자 판별 API (서버 전용 — 절대 NEXT_PUBLIC_ 접두사 금지, 브라우저 노출 금지)
OFFICIAL_CHECK_KEY=            # IT팀이 별도 채널로 전달하는 발급 키. 소스/저장소에 커밋 금지.
OFFICIAL_CHECK_URL=https://hanaro.ffwp.or.kr/API_kim/officialLoginCheck2
