# Nexus Core 환경변수 설정 (.env)

# --- 데이터베이스 접속 URL ---
# [로컬 개발] Docker Compose 내부 DB
DATABASE_URL=postgresql+asyncpg://nexus_user:nexus_pass@db:5432/nexus_core
# [프로덕션] Neon (direct connection, ssl=require 포함)
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?ssl=require

# --- Auth (하나로 SSO 단독) ---
# 로그인 성공 시 발급하는 세션 JWT(HS256) 서명 키. 충분히 긴 무작위 문자열로 생성할 것.
#   생성 예: LC_ALL=C tr -dc 'a-f0-9' < /dev/urandom | head -c 48
AUTH_JWT_SECRET=
# 세션 유효 시간(시간 단위). 만료되면 재로그인한다(refresh 토큰 없음).
AUTH_JWT_EXPIRE_HOURS=12

# 외부 IdP(JWKS) 검증 경로. 하나로 단독 운영에서는 비워둔다.
# AUTH_JWKS_URL=

# --- 하나로 SSO (공직자 판별 API v2) ---
# 규격서 2026-07-16 v2 기준. 발급 키는 20자 이상 무작위 문자열이며 IT팀이 별도 채널로 전달한다.
# 소스·저장소에 커밋 금지. v1 키를 v2 주소에 쓰면 업스트림이 invalid_key 로 거부한다.
OFFICIAL_CHECK_KEY=
OFFICIAL_CHECK_URL=https://hanaro.ffwp.or.kr/API_kim/officialLoginCheck2

# --- AI API 키 ---
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- 앱 설정 ---
DEBUG=true
CORS_ORIGINS="http://localhost:3000"

# --- Cloudflare R2 ---
STORAGE_PROVIDER=r2
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-custom-domain.example.com

# --- 카카오톡 채널 챗봇 ---
# 카카오 i 오픈빌더 스킬 콜백 인증용 공유 시크릿.
# 임의의 긴 랜덤 문자열을 생성(예: `openssl rand -hex 32`)해서 이 값과
# 오픈빌더 스킬의 '헤더값'에 동일하게 넣는다.
# ⚠️ 비워두면 /api/v1/kakao/callback 엔드포인트가 무인증(개방) 상태가 되어
#    누구나 호출 → LLM 비용/SSRF 위험. 프로덕션에서는 반드시 설정할 것.
KAKAO_SKILL_SECRET=
# (선택) 인증에 사용할 HTTP 헤더 이름. 오픈빌더 스킬의 헤더 키와 일치해야 한다. 기본값 권장.
KAKAO_SKILL_SECRET_HEADER=X-Kakao-Skill-Secret
# (선택) 콜백 URL 로 POST 를 허용할 호스트 suffix (콤마 구분, SSRF 차단용).
# 실제 콜백 URL 의 host 가 다르면 서버 로그를 보고 도메인을 추가한다. 기본 .kakao.com.
KAKAO_CALLBACK_ALLOWED_HOSTS=.kakao.com
