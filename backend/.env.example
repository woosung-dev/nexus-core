# Nexus Core 환경변수 설정 (.env)

# --- 데이터베이스 접속 URL ---
# [로컬 개발] Docker Compose 내부 DB
DATABASE_URL=postgresql+asyncpg://nexus_user:nexus_pass@db:5432/nexus_core
# [프로덕션] Neon (direct connection, ssl=require 포함)
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?ssl=require

# --- Auth (Clerk) ---
# Clerk JWKS URL: Dashboard > API Keys > "Show JWT public key" 하단 링크
AUTH_JWKS_URL=https://<clerk-frontend-api>.clerk.accounts.dev/.well-known/jwks.json

# --- AI API 키 ---
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# --- 앱 설정 ---
DEBUG=true
CORS_ORIGINS="http://localhost:3000"

# --- Cloudflare R2 ---
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-custom-domain.example.com
